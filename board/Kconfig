            config BSP_USING_SOFT_I2C5
                bool "Enable Soft I2C5"
                default n
            if BSP_USING_SOFT_I2C5
                config BSP_SOFT_I2C5_SCL_PIN
                    string "Soft I2C5 SCL pin name"
                    default "None"
                config BSP_SOFT_I2C5_SDA_PIN
                    string "Soft I2C5 SDA pin name"
                    default "None"
            endif

            config BSP_USING_SOFT_I2C6
                bool "Enable Soft I2C6"
                default n
            if BSP_USING_SOFT_I2C6
                config BSP_SOFT_I2C6_SCL_PIN
                    string "Soft I2C6 SCL pin name"
                    default "None"
                config BSP_SOFT_I2C6_SDA_PIN
                    string "Soft I2C6 SDA pin name"
                    default "None"
            endif

            config BSP_USING_SOFT_I2C7
                bool "Enable Soft I2C7"
                default n
            if BSP_USING_SOFT_I2C7
                config BSP_SOFT_I2C7_SCL_PIN
                    string "Soft I2C7 SCL pin name"
                    default "None"
                config BSP_SOFT_I2C7_SDA_PIN
                    string "Soft I2C7 SDA pin name"
                    default "None"
            endif

            config BSP_USING_SOFT_I2C8
                bool "Enable Soft I2C8"
                default n
            if BSP_USING_SOFT_I2C8
                config BSP_SOFT_I2C8_SCL_PIN
                    string "Soft I2C8 SCL pin name"
                    default "None"
                config BSP_SOFT_I2C8_SDA_PIN
                    string "Soft I2C8 SDA pin name"
                    default "None"
            endif

        endif

    menuconfig BSP_USING_SOFT_SPI
        bool "Enable Software SPI"
        default n
        select RT_USING_SPI if BSP_USING_SOFT_SPI
        select RT_USING_PIN if BSP_USING_SOFT_SPI
        select RT_USING_SPI_BITOPS if BSP_USING_SOFT_SPI
        if BSP_USING_SOFT_SPI

            config BSP_USING_SOFT_SPI_TIMING_DELAY_US
                int "Soft SPI timing delay in microseconds"
                range 1 1000
                default 1

            config BSP_USING_SOFT_SPI0
                bool "Enable Soft SPI0"
                default n
            if BSP_USING_SOFT_SPI0
                config BSP_SOFT_SPI0_SCK_PIN
                    string "Soft SPI0 SCK pin name"
                    default "None"
                config BSP_SOFT_SPI0_MOSI_PIN
                    string "Soft SPI0 MOSI pin name"
                    default "None"
                config BSP_SOFT_SPI0_MISO_PIN
                    string "Soft SPI0 MISO pin name"
                    default "None"
            endif

            config BSP_USING_SOFT_SPI1
                bool "Enable Soft SPI1"
                default n
            if BSP_USING_SOFT_SPI1
                config BSP_SOFT_SPI1_SCK_PIN
                    string "Soft SPI1 SCK pin name"
                    default "None"
                config BSP_SOFT_SPI1_MOSI_PIN
                    string "Soft SPI1 MOSI pin name"
                    default "None"
                config BSP_SOFT_SPI1_MISO_PIN
                    string "Soft SPI1 MISO pin name"
                    default "None"
            endif

            config BSP_USING_SOFT_SPI2
                bool "Enable Soft SPI2"
                default n
            if BSP_USING_SOFT_SPI2
                config BSP_SOFT_SPI2_SCK_PIN
                    string "Soft SPI2 SCK pin name"
                    default "None"
                config BSP_SOFT_SPI2_MOSI_PIN
                    string "Soft SPI2 MOSI pin name"
                    default "None"
                config BSP_SOFT_SPI2_MISO_PIN
                    string "Soft SPI2 MISO pin name"
                    default "None"
            endif

        endif

