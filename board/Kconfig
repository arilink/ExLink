    config HPM_BSP_USING_GENERIC_STARTUP
        bool "Enable this to use the common/startup/generic implementation"
        default n
        depends on HPM_USING_RTTHREAD_INTERRUPT_FRAMEWORK
        help
            Enable this to use the common/startup/generic implementation.
            This option is only available when RT-Thread Interrupt Framework is enabled.
endmenu

menu "HPMicro RT-Thread backtrace configuration (experimental)"
    config HPM_ENABLE_RTTHREAD_BACKTRACE_PORT
        bool "Enable RT-Thread Backtrace for HPMicro BSP"
        default n
        help
            Enable RT-Thread Backtrace to support backtrace feature

    config HPM_USE_RTTHREAD_BACKTRACE_IN_EXCEPTION_HANDLER
        select HPM_ENABLE_RTTHREAD_BACKTRACE_PORT
        bool "Use RT-Thread Backtrace in Exception Handler"
        default n
